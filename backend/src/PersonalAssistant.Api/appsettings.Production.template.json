{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "Database": {
    "Provider": "SqlServer",
    "ConnectionStrings": {
      "SqlServer": "Server=tcp:<server>.database.windows.net,1433;Initial Catalog=<database>;Encrypt=True;TrustServerCertificate=False;"
    }
  },
  "Cors": {
    "AllowedOrigins": [
      "https://<your-frontend-host>"
    ]
  },
  "Jwt": {
    "Issuer": "PersonalAssistant",
    "Audience": "PersonalAssistant.Client",
    "SigningKey": "<set-from-secret-store-or-environment>",
    "ExpiryMinutes": 120
  }
}
